{
  "entities": {
    "User": {
      "title": "User",
      "description": "Information about a registered player.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Firebase Auth UID." },
        "displayName": { "type": "string", "description": "User's public name." },
        "photoURL": { "type": "string", "description": "User's avatar URL." },
        "email": { "type": "string", "description": "User's email address." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user first logged in." }
      },
      "required": ["userId", "displayName", "email"]
    },
    "LeaderboardEntry": {
      "title": "LeaderboardEntry",
      "description": "A record of a user's total performance for ranking.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Firebase Auth UID." },
        "displayName": { "type": "string", "description": "User's public name." },
        "photoURL": { "type": "string", "description": "User's avatar URL." },
        "totalPoints": { "type": "integer", "description": "Total points accumulated across all levels." },
        "totalTimeSeconds": { "type": "number", "description": "Total time taken to complete levels in seconds." },
        "levelsCount": { "type": "integer", "description": "Number of levels completed." },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last time the score was updated." }
      },
      "required": ["userId", "displayName", "totalPoints", "totalTimeSeconds", "levelsCount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profiles."
    },
    "/leaderboard/{userId}": {
      "schema": "LeaderboardEntry",
      "description": "Public leaderboard entries for ranking."
    }
  }
}
